# Usado pelo docker-compose.yml (raiz do projeto). Para correr backend/frontend
# localmente com pnpm, usa antes apps/backend/.env e apps/frontend/.env.
POSTGRES_USER=opencrm
POSTGRES_PASSWORD=changeme
POSTGRES_DB=opencrm

BACKEND_PORT=3000
JWT_SECRET=changeme_jwt_secret
JWT_REFRESH_SECRET=changeme_jwt_refresh_secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

FRONTEND_PORT=5173
VITE_API_URL=http://localhost:3000

INTERNAL_API_KEY=changeme_internal_api_key

EMAIL_ADDRESS=
EMAIL_PASSWORD=
IMAP_HOST=
IMAP_PORT=993
IMAP_SECURE=true
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true

MINIO_ACCESS_KEY=opencrm
MINIO_SECRET_KEY=changeme_minio_secret
MINIO_BUCKET=email-attachments
