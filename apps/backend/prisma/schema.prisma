generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMINISTRADOR
  COMERCIAL
  TECNICO
  BACKOFFICE
  FINANCEIRO
  LEITURA_APENAS
}

model User {
  id                  String          @id @default(uuid())
  email               String          @unique
  name                String
  passwordHash        String
  role                Role            @default(COMERCIAL)
  refreshToken        String?
  resetToken          String?         @unique
  resetTokenExpiresAt DateTime?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  timelineEvents      TimelineEvent[]
  deals               Deal[]
  tasks               Task[]
  leads               Lead[]
  ownedCompanies      Company[]
  ownedContacts       Contact[]
}

enum TimelineEventType {
  NOTE
  CALL
  EMAIL
  MEETING
  FILE
  SYSTEM
}

enum TimelineEntityType {
  COMPANY
  CONTACT
  LEAD
  DEAL
  TASK
}

model TimelineEvent {
  id          String             @id @default(uuid())
  entityType  TimelineEntityType
  entityId    String
  userId      String
  user        User               @relation(fields: [userId], references: [id])
  type        TimelineEventType  @default(NOTE)
  title       String?
  description String?
  metadata    Json?
  createdAt   DateTime           @default(now())

  @@index([entityType, entityId])
}

enum CompanyStatus {
  ATIVO
  POTENCIAL
  INATIVO
  PERDIDO
}

enum CompanySource {
  SITE
  LOJA
  CHAMADA
  CAMPANHA
  IMPORTACAO
  RECOMENDACAO
  OUTRO
}

enum PreferredChannel {
  TELEFONE
  EMAIL
  WHATSAPP
  PRESENCIAL
}

model Company {
  id         String         @id @default(uuid())
  name       String
  legalName  String?
  taxId      String?
  website    String?
  phone      String?
  email      String?
  address    String?
  postalCode String?
  city       String?
  country    String?
  status     CompanyStatus  @default(POTENCIAL)
  source     CompanySource?
  ownerId    String?
  owner      User?          @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  notes      String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  contacts   Contact[]
  deals      Deal[]
  tasks      Task[]
  emails     EmailMessage[]

  @@index([ownerId])
}

model Contact {
  id               String            @id @default(uuid())
  name             String
  email            String?
  phone            String?
  mobilePhone      String?
  jobTitle         String?
  department       String?
  preferredChannel PreferredChannel?
  isDecisionMaker  Boolean           @default(false)
  marketingConsent Boolean           @default(false)
  notes            String?
  companyId        String?
  company          Company?          @relation(fields: [companyId], references: [id], onDelete: SetNull)
  ownerId          String?
  owner            User?             @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  deals            Deal[]
  tasks            Task[]
  emails           EmailMessage[]

  @@index([companyId])
  @@index([ownerId])
}

enum StageType {
  OPEN
  WON
  LOST
}

model Pipeline {
  id              String           @id @default(uuid())
  name            String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  stages          Stage[]
  deals           Deal[]
  automationRules AutomationRule[]
}

model Stage {
  id              String           @id @default(uuid())
  name            String
  order           Int
  type            StageType        @default(OPEN)
  pipelineId      String
  pipeline        Pipeline         @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  deals           Deal[]
  automationRules AutomationRule[]

  @@index([pipelineId])
}

model Deal {
  id              String        @id @default(uuid())
  title           String
  value           Float         @default(0)
  probability     Int           @default(0)
  order           Int           @default(0)
  type            BusinessArea?
  estimatedMargin Float?
  lossReason      String?
  pipelineId      String
  pipeline        Pipeline      @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  stageId         String
  stage           Stage         @relation(fields: [stageId], references: [id], onDelete: Restrict)
  stageEnteredAt  DateTime      @default(now())
  contactId       String?
  contact         Contact?      @relation(fields: [contactId], references: [id], onDelete: SetNull)
  companyId       String?
  company         Company?      @relation(fields: [companyId], references: [id], onDelete: SetNull)
  ownerId         String
  owner           User          @relation(fields: [ownerId], references: [id])
  closedAt        DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  tasks           Task[]
  lead            Lead?

  @@index([pipelineId])
  @@index([stageId])
}

enum AutomationTriggerType {
  STAGE_IDLE_TIME
  TASK_COMPLETED
  FIELD_CHANGED
}

enum AutomationActionType {
  MOVE_STAGE
  TRIGGER_WEBHOOK
}

model AutomationRule {
  id            String                @id @default(uuid())
  name          String
  active        Boolean               @default(true)
  pipelineId    String?
  pipeline      Pipeline?             @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  stageId       String?
  stage         Stage?                @relation(fields: [stageId], references: [id], onDelete: Cascade)
  triggerType   AutomationTriggerType
  triggerConfig Json
  actionType    AutomationActionType
  actionConfig  Json
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  @@index([pipelineId])
  @@index([stageId])
  @@index([triggerType, active])
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  DONE
}

enum TaskType {
  CHAMADA
  EMAIL
  VISITA
  PROPOSTA
  COBRANCA
  ASSISTENCIA
  OUTRO
}

enum TaskPriority {
  BAIXA
  NORMAL
  ALTA
  URGENTE
}

model Task {
  id          String       @id @default(uuid())
  title       String
  description String?
  status      TaskStatus   @default(PENDING)
  type        TaskType?
  priority    TaskPriority @default(NORMAL)
  result      String?
  dueDate     DateTime?
  assigneeId  String
  assignee    User         @relation(fields: [assigneeId], references: [id])
  contactId   String?
  contact     Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)
  companyId   String?
  company     Company?     @relation(fields: [companyId], references: [id], onDelete: SetNull)
  dealId      String?
  deal        Deal?        @relation(fields: [dealId], references: [id], onDelete: SetNull)
  leadId      String?
  lead        Lead?        @relation(fields: [leadId], references: [id], onDelete: SetNull)
  reminders   Reminder[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([assigneeId])
  @@index([dueDate])
}

model Reminder {
  id        String   @id @default(uuid())
  remindAt  DateTime
  message   String?
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([taskId])
}

enum EmailDirection {
  INBOUND
  OUTBOUND
}

model EmailAccount {
  id         String         @id @default(uuid())
  email      String         @unique
  imapHost   String
  imapPort   Int
  imapSecure Boolean        @default(true)
  smtpHost   String
  smtpPort   Int
  smtpSecure Boolean        @default(true)
  username   String
  password   String
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  messages   EmailMessage[]
}

model EmailMessage {
  id          String         @id @default(uuid())
  accountId   String
  account     EmailAccount   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  direction   EmailDirection
  messageId   String         @unique
  fromAddress String
  fromName    String?
  toAddresses String[]
  subject     String?
  textBody    String?
  htmlBody    String?
  contactId   String?
  contact     Contact?       @relation(fields: [contactId], references: [id], onDelete: SetNull)
  companyId   String?
  company     Company?       @relation(fields: [companyId], references: [id], onDelete: SetNull)
  attachments Attachment[]
  sentAt      DateTime
  createdAt   DateTime       @default(now())

  @@index([accountId])
  @@index([contactId])
  @@index([companyId])
}

model Attachment {
  id         String       @id @default(uuid())
  messageId  String
  message    EmailMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  filename   String
  mimeType   String
  size       Int
  storageKey String
  createdAt  DateTime     @default(now())

  @@index([messageId])
}

model EmailTemplate {
  id        String   @id @default(uuid())
  name      String
  subject   String
  body      String
  category  String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum BusinessArea {
  IMPRESSAO
  SOFTWARE
  INFORMATICA
  PAPELARIA
  POS
  ASSISTENCIA
  OUTRO
}

enum LeadStatus {
  NOVO
  CONTACTADO
  SEM_RESPOSTA
  CONVERTIDO
  PERDIDO
}

model Lead {
  id              String        @id @default(uuid())
  name            String
  companyName     String?
  phone           String?
  email           String?
  source          String?
  interest        BusinessArea?
  status          LeadStatus    @default(NOVO)
  responsavelId   String?
  responsavel     User?         @relation(fields: [responsavelId], references: [id], onDelete: SetNull)
  nextActionAt    DateTime?
  notes           String?
  convertedDealId String?       @unique
  convertedDeal   Deal?         @relation(fields: [convertedDealId], references: [id], onDelete: SetNull)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  tasks           Task[]

  @@index([responsavelId])
  @@index([status])
}

enum CustomFieldEntityType {
  COMPANY
  CONTACT
  LEAD
  DEAL
}

enum CustomFieldType {
  TEXT
  TEXTAREA
  NUMBER
  CURRENCY
  DATE
  BOOLEAN
  SELECT
  MULTISELECT
  EMAIL
  PHONE
  URL
}

model CustomField {
  id                  String                @id @default(uuid())
  entityType          CustomFieldEntityType
  sectionName         String?
  fieldName           String
  fieldLabel          String
  fieldType           CustomFieldType
  options             Json?
  isRequired          Boolean               @default(false)
  isVisible           Boolean               @default(true)
  isSearchable        Boolean               @default(false)
  isFilterable        Boolean               @default(false)
  isAutomationEnabled Boolean               @default(false)
  sortOrder           Int                   @default(0)
  permissions         Json?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  values              CustomFieldValue[]

  @@unique([entityType, fieldName])
}

model CustomFieldValue {
  id            String                @id @default(uuid())
  customFieldId String
  customField   CustomField           @relation(fields: [customFieldId], references: [id], onDelete: Cascade)
  entityType    CustomFieldEntityType
  entityId      String
  valueText     String?
  valueNumber   Float?
  valueDate     DateTime?
  valueBoolean  Boolean?
  valueJson     Json?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  @@unique([customFieldId, entityId])
  @@index([entityType, entityId])
}
