# Usado pelo Prisma/NestJS quando corridos localmente (fora do Docker) — Prisma
# carrega este ficheiro automaticamente por estar na pasta apps/backend.
DATABASE_URL=postgresql://opencrm:changeme@localhost:5432/opencrm?schema=public

BACKEND_PORT=3000
JWT_SECRET=changeme_jwt_secret
JWT_REFRESH_SECRET=changeme_jwt_refresh_secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# URL do frontend, usada para construir o link de recuperação de password
FRONTEND_URL=http://localhost:5173

# URL do webhook do n8n para automações (Fase 5). Deixa vazio para desativar.
N8N_WEBHOOK_URL=

# Usado para autenticar o email-worker nas chamadas internas (POST /email/ingest)
INTERNAL_API_KEY=changeme_internal_api_key

# Caixa de email partilhada (Fase 4)
EMAIL_ADDRESS=
EMAIL_PASSWORD=
IMAP_HOST=
IMAP_PORT=993
IMAP_SECURE=true
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true

# MinIO (armazenamento de anexos, S3-compatible)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=opencrm
MINIO_SECRET_KEY=changeme_minio_secret
MINIO_BUCKET=email-attachments
MINIO_USE_SSL=false
